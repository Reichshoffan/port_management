<odoo>
    <data>

        <!-- Vue Liste -->
        <record id="view_port_gps_list" model="ir.ui.view">
            <field name="name">port.gps.list</field>
            <field name="model">port.gps</field>
            <field name="arch" type="xml">
                <list string="GPS">
                    <field name="reference"/>
                    <field name="name"/>
                    <field name="modele"/>
                    <field name="numero_serie"/>
                    <field name="imei"/>
                    <field name="date_acquisition"/>
                    <field name="etat" widget="badge"
                           decoration-success="etat == 'stock'"
                           decoration-info="etat == 'affecte'"
                           decoration-warning="etat == 'maintenance'"
                           decoration-danger="etat == 'hors_service'"/>
                </list>
            </field>
        </record>

        <!-- Vue Formulaire -->
        <record id="view_port_gps_form" model="ir.ui.view">
            <field name="name">port.gps.form</field>
            <field name="model">port.gps</field>
            <field name="arch" type="xml">
                <form string="GPS">
                    <sheet>
                        <group>
                            <group>
                                <field name="reference"/>
                                <field name="name"/>
                                <field name="modele"/>
                                <field name="numero_serie"/>
                            </group>

                            <group>
                                <field name="imei"/>
                                <field name="date_acquisition"/>
                                <field name="etat"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action -->
        <record id="action_port_gps" model="ir.actions.act_window">
            <field name="name">GPS</field>
            <field name="res_model">port.gps</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>