<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>


        <!-- Vue Liste -->
        <record id="view_port_type_cargaison_list" model="ir.ui.view">
            <field name="name">port.type.cargaison.list</field>
            <field name="model">port.type.cargaison</field>
            <field name="arch" type="xml">
                <list string="Types de cargaison">
                    <field name="name"/>
                </list>
            </field>
        </record>

        <!-- Vue Formulaire -->
        <record id="view_port_type_cargaison_form" model="ir.ui.view">
            <field name="name">port.type.cargaison.form</field>
            <field name="model">port.type.cargaison</field>
            <field name="arch" type="xml">
                <form string="Type de cargaison">
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                        <notebook>
                            <page string="Tarification">
                                <field name="tarif_line_ids">
                                      <list editable="bottom">
                                        <field name="product_id"/>
                                        <field name="prix"/>
                                      </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>


        <!-- Action -->
        <record id="action_port_type_cargaison" model="ir.actions.act_window">
            <field name="name">Types de cargaison</field>
            <field name="res_model">port.type.cargaison</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>
